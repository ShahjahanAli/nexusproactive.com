{
  "name": "nexus-widget",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev -w @nexus/api",
    "dev:dashboard": "npm run dev -w @nexus/dashboard",
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w @nexus/api",
    "db:rollback": "npm run db:rollback -w @nexus/api",
    "db:migrate:status": "npm run db:migrate:status -w @nexus/api",
    "db:baseline": "npm run db:baseline -w @nexus/api",
    "db:make:migration": "npm run db:make:migration -w @nexus/api",
    "dev:widget": "npm run dev -w @nexus/widget",
    "start:api": "npm run start -w @nexus/api",
    "start:dashboard": "npm run start -w @nexus/dashboard",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --env production",
    "pm2:logs": "pm2 logs"
  },
  "engines": {
    "node": ">=20"
  }
}
