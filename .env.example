# API
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus_widget

# Redis — disabled by default in development; set REDIS_ENABLED=true to use it locally
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:6100
DASHBOARD_URL=http://localhost:6100

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# LLM — any OpenAI-compatible /v1/chat/completions endpoint
# Examples:
#   OpenAI:  https://api.openai.com/v1
#   LiteLLM: https://litellm.example.com/v1
#   Ollama:  http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=gpt-4o

# Legacy aliases (still supported)
# LITELLM_BASE_URL=
# LITELLM_API_KEY=

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:5000

# Public URL of your API (used in widget embed snippets; set in production)
# PUBLIC_API_URL=https://api.yourdomain.com
